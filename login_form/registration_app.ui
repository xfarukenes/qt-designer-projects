    <property name="styleSheet">
     <string notr="true">#delete_button {
    background-color: #e74c3c; /* Modern bir kırmızı (Alizarin) */
    color: white;              /* Beyaz yazı */
    border-radius: 15px;      /* Diğer butonlarla aynı ovalik */
    font-weight: bold;         /* Yazıyı biraz kalınlaştıralım */
    border: 1px solid #c0392b; /* Daha koyu kırmızı ince kenarlık */
    padding: 5px;
}

/* Mouse ile üzerine gelindiğinde rengi biraz koyulaşsın */
#delete_button:hover {
    background-color: #c0392b; /* Üzerine gelince koyu kırmızı (Pomegranate) */
}

/* Butona tıklandığı anki efekt */
#delete_button:pressed {
    background-color: #a93226; /* Tıklandığında en koyu hali */
}</string>
